# ──────────────────────────────────────────────
# AutoCoder — Local Development Environment
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
# ──────────────────────────────────────────────

# ── Server Ports ──────────────────────────────
# API server port (default: 3001)
# PORT=3001

# ── Frontend ──────────────────────────────────
# Base path for the frontend (default: /)
# BASE_PATH=/

# ── AI / LLM Configuration ───────────────────
# The OpenAI SDK is used for all AI calls. It works with any
# OpenAI-compatible server: Ollama, LM Studio, Jan, vLLM, etc.

# For Ollama (recommended):
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_MODEL=llama3.2

# For LM Studio:
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# OPENAI_MODEL=local-model

# For cloud OpenAI:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Local LLM (Ollama native API) ────────────
# Used by the local-llm-client module for direct Ollama calls
# (understand, edit, fix endpoints). Separate from the OpenAI SDK.
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=llama3.2

# ── Database ──────────────────────────────────
# PostgreSQL connection string. If omitted, the app runs with
# in-memory storage (data lost on restart — fine for development).
# DATABASE_URL=postgresql://user:password@localhost:5432/autocoder

# ── Vite Proxy Target ────────────────────────
# The Vite dev server proxies /api and /cache to this URL.
# Only needed if the API server runs on a non-default port.
# VITE_API_BASE=http://localhost:3001
