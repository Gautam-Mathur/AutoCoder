# ──────────────────────────────────────────────
# AutoCoder — Local Development Environment
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
# ──────────────────────────────────────────────

# ── Server Ports ──────────────────────────────
# API server port (default: 3001)
# PORT=3001

# ── Frontend ──────────────────────────────────
# Base path for the frontend (default: /)
# BASE_PATH=/

# ── AI / LLM Configuration ───────────────────
# The OpenAI SDK is used for all AI calls. It works with any
# OpenAI-compatible server: Ollama, LM Studio, Jan, vLLM, etc.

# For Ollama (recommended for best code quality):
# qwen2.5-coder:7b = best for 6GB+ GPU / 8GB RAM (coding-specific model)
# qwen2.5-coder:14b = excellent for 10GB+ GPU (near cloud-model quality)
# deepseek-coder-v2:16b = near-Claude for code on 12GB+ GPU
# DO NOT use llama3.2 — it is a general model, not optimized for code generation
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
# OPENAI_API_KEY is intentionally a dummy value — Ollama does not require a real key
OPENAI_MODEL=qwen2.5-coder:7b

# For LM Studio:
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# OPENAI_MODEL=local-model

# For cloud OpenAI:
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── Local LLM (Ollama native API) ────────────
# Used by the local-llm-client module for direct Ollama calls.
# If not set, falls back to OPENAI_MODEL automatically.
LOCAL_LLM_URL=http://localhost:11434
LOCAL_LLM_MODEL=qwen2.5-coder:7b

# ── SLM Engine Tuning ────────────────────────
# Context window for SLM stages (default: 16384)
# Raise if your model supports more context (e.g. 32768)
# SLM_CONTEXT_SIZE=16384

# ── Database ──────────────────────────────────
# PostgreSQL connection string. If omitted, the app runs with
# in-memory storage (data lost on restart — fine for development).
# DATABASE_URL=postgresql://user:password@localhost:5432/autocoder

# ── Vite Proxy Target ────────────────────────
# The Vite dev server proxies /api and /cache to this URL.
# Only needed if the API server runs on a non-default port.
# VITE_API_BASE=http://localhost:3001
